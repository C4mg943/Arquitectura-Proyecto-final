@startuml Casos_de_Uso_Nivel_1_UC03
left to right direction

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #D6E4F0
  BorderColor #2E75B6
  FontColor #1F4E79
  FontSize 12
}
skinparam actor {
  BackgroundColor #EAF4FB
  BorderColor #2E75B6
  FontColor #1F4E79
}
skinparam ArrowColor #2E75B6

' Actores
actor "Productor\nAgrícola" as Productor
actor "Técnico\nAgrónomo" as Tecnico

' Sistema
rectangle "Gestionar Cultivos" {

    ' CRUD (arriba)
    usecase "Registrar Cultivo" as UC03_1
    usecase "Modificar Cultivo" as UC03_2
    usecase "Eliminar Cultivo" as UC03_3
    usecase "Listar Cultivos" as UC03_4

    ' Consultas (abajo)
    usecase "Buscar Cultivo\npor Tipo" as UC03_5
    usecase "Consultar Detalle\nde Cultivo" as UC03_6

    ' Relaciones correctas
    UC03_5 .> UC03_4 : <<extend>>
    UC03_6 .> UC03_4 : <<extend>>
}

' Relaciones actores
Productor --> UC03_1
Productor --> UC03_2
Productor --> UC03_3
Productor --> UC03_4


Tecnico --> UC03_4
Tecnico --> UC03_6

@enduml